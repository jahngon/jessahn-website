---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const artifacts = (await getCollection('artifacts')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const entries = (await getCollection('entries')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout title="Jess Ahn">
	<nav class="nav">
		<a class="nav-wordmark" href="/">Jess Ahn</a>
		<div class="nav-items">
			<a href="/#artifacts">Artifacts</a>
			<a href="/#writing">Writing</a>
			<a href="/#about">About</a>
			<a class="say-hi" href="https://www.linkedin.com/in/jessicaahn/" target="_blank" rel="noopener">Say hi</a>
		</div>
	</nav>

	<h1>
		Hi, I'm Jess. I build and operate
		<span class="squiggle-wrap">
			<em>GTM systems</em>
			<svg class="squiggle" viewBox="0 0 260 18" preserveAspectRatio="none" aria-hidden="true">
				<path d="M 4 10 Q 16 3, 28 10 T 52 10 T 76 10 T 100 10 T 124 10 T 148 10 T 172 10 T 196 10 T 220 10 T 244 10 T 256 10"
					fill="none" stroke="#1B4FCC" stroke-width="3"
					stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</span>
		and the tools behind them.
	</h1>

	<p class="intro">
		Currently building for and advising startups with their GTM operations — and, most importantly, parenting a spicy little one. Sharing what I've made to help anyone navigating the <span class="highlight">crazy (good)</span> of GTM and parenthood. Based in San Francisco and looking for teams that care about security and design in equal measure.
	</p>

	<p class="built-with">
		Built with
		<a href="https://www.anthropic.com/claude-code" target="_blank" rel="noopener" aria-label="Claude Code">
			<svg class="built-with-logo" viewBox="0 0 248 248" fill="none" aria-hidden="true">
				<path d="M52.4285 162.873L98.7844 136.879L99.5485 134.602L98.7844 133.334H96.4921L88.7237 132.862L62.2346 132.153L39.3113 131.207L17.0249 130.026L11.4214 128.844L6.2 121.873L6.7094 118.447L11.4214 115.257L18.171 115.847L33.0711 116.911L55.485 118.447L71.6586 119.392L95.728 121.873H99.5485L100.058 120.337L98.7844 119.392L97.7656 118.447L74.5877 102.732L49.4995 86.1905L36.3823 76.62L29.3779 71.7757L25.8121 67.2858L24.2839 57.3608L30.6515 50.2716L39.3113 50.8623L41.4763 51.4531L50.2636 58.1879L68.9842 72.7209L93.4357 90.6804L97.0015 93.6343L98.4374 92.6652L98.6571 91.9801L97.0015 89.2625L83.757 65.2772L69.621 40.8192L63.2534 30.6579L61.5978 24.632C60.9565 22.1032 60.579 20.0111 60.579 17.4246L67.8381 7.49965L71.9133 6.19995L81.7193 7.49965L85.7946 11.0443L91.9074 24.9865L101.714 46.8451L116.996 76.62L121.453 85.4816L123.873 93.6343L124.764 96.1155H126.292V94.6976L127.566 77.9197L129.858 57.3608L132.15 30.8942L132.915 23.4505L136.608 14.4708L143.994 9.62643L149.725 12.344L154.437 19.0788L153.8 23.4505L150.998 41.6463L145.522 70.1215L141.957 89.2625H143.994L146.414 86.7813L156.093 74.0206L172.266 53.698L179.398 45.6635L187.803 36.802L193.152 32.5484H203.34L210.726 43.6549L207.415 55.1159L196.972 68.3492L188.312 79.5739L175.896 96.2095L168.191 109.585L168.882 110.689L170.738 110.53L198.755 104.504L213.91 101.787L231.994 98.7149L240.144 102.496L241.036 106.395L237.852 114.311L218.495 119.037L195.826 123.645L162.07 131.592L161.696 131.893L162.137 132.547L177.36 133.925L183.855 134.279H199.774L229.447 136.524L237.215 141.605L241.8 147.867L241.036 152.711L229.065 158.737L213.019 154.956L175.45 145.977L162.587 142.787H160.805V143.85L171.502 154.366L191.242 172.089L215.82 195.011L217.094 200.682L213.91 205.172L210.599 204.699L188.949 188.394L180.544 181.069L161.696 165.118H160.422V166.772L164.752 173.152L187.803 207.771L188.949 218.405L187.294 221.832L181.308 223.959L174.813 222.777L161.187 203.754L147.305 182.486L136.098 163.345L134.745 164.2L128.075 235.42L125.019 239.082L117.887 241.8L111.902 237.31L108.718 229.984L111.902 215.452L115.722 196.547L118.779 181.541L121.58 162.873L123.291 156.636L123.14 156.219L121.773 156.449L107.699 175.752L86.304 204.699L69.3663 222.777L65.291 224.431L58.2867 220.768L58.9235 214.27L62.8713 208.48L86.304 178.705L100.44 160.155L109.551 149.507L109.462 147.967L108.959 147.924L46.6977 188.512L35.6182 189.93L30.7788 185.44L31.4156 178.115L33.7079 175.752L52.4285 162.873Z" fill="#D97757"/>
			</svg>
		</a><span class="built-with-sep">,</span>
		<a href="https://github.com" target="_blank" rel="noopener" aria-label="GitHub">
			<svg class="built-with-logo" viewBox="0 0 32 32" fill="none" aria-hidden="true">
				<path fill-rule="evenodd" clip-rule="evenodd" d="M16 0C7.16 0 0 7.16 0 16C0 23.08 4.58 29.06 10.94 31.18C11.74 31.32 12.04 30.84 12.04 30.42C12.04 30.04 12.02 28.78 12.02 27.44C8 28.18 6.96 26.46 6.64 25.56C6.46 25.1 5.68 23.68 5 23.3C4.44 23 3.64 22.26 4.98 22.24C6.24 22.22 7.14 23.4 7.44 23.88C8.88 26.3 11.18 25.62 12.1 25.2C12.24 24.16 12.66 23.46 13.12 23.06C9.56 22.66 5.84 21.28 5.84 15.16C5.84 13.42 6.46 11.98 7.48 10.86C7.32 10.46 6.76 8.82 7.64 6.62C7.64 6.62 8.98 6.2 12.04 8.26C13.32 7.9 14.68 7.72 16.04 7.72C17.4 7.72 18.76 7.9 20.04 8.26C23.1 6.18 24.44 6.62 24.44 6.62C25.32 8.82 24.76 10.46 24.6 10.86C25.62 11.98 26.24 13.4 26.24 15.16C26.24 21.3 22.5 22.66 18.94 23.06C19.52 23.56 20.02 24.52 20.02 26.02C20.02 28.16 20 29.88 20 30.42C20 30.84 20.3 31.34 21.1 31.18C27.42 29.06 32 23.06 32 16C32 7.16 24.84 0 16 0V0Z" fill="#24292E"/>
			</svg>
		</a>
		and
		<a href="https://vercel.com" target="_blank" rel="noopener" aria-label="Vercel">
			<svg class="built-with-logo" viewBox="0 0 256 222" fill="none" aria-hidden="true">
				<path d="M128 0l128 221.705H0z" fill="#000"/>
			</svg>
		</a>
	</p>

	<div class="links">
		<a href="https://www.linkedin.com/in/jessicaahn/" target="_blank" rel="noopener">Message me on LinkedIn</a>
		<a href="#about">More about me</a>
	</div>

	{artifacts.length > 0 && (
		<section class="section" id="artifacts">
			<h2 class="section-label">Artifacts</h2>
			<ul class="list">
				{artifacts.map((entry) => (
					<li class="list-item">
						<a href={`/artifacts/${entry.id}`}>
							<div class="list-item-main">
								<h3 class="list-item-title">{entry.data.title}</h3>
								<p class="list-item-desc">{entry.data.description}</p>
							</div>
							<span class="list-item-tag">{entry.data.category}</span>
						</a>
					</li>
				))}
			</ul>
		</section>
	)}

	{entries.length > 0 && (
		<section class="section" id="writing">
			<h2 class="section-label">Writing</h2>
			<ul class="list">
				{entries.map((entry) => (
					<li class="list-item">
						<a href={`/entries/${entry.id}`}>
							<div class="list-item-main">
								<h3 class="list-item-title">{entry.data.title}</h3>
								<p class="list-item-desc">{entry.data.description}</p>
							</div>
							<span class="list-item-tag">{entry.data.category}</span>
						</a>
					</li>
				))}
			</ul>
		</section>
	)}

	<section class="section" id="about">
		<h2 class="section-label">About</h2>
		<div class="prose">
			<p>Hi, I'm Jess Ahn, a go-to-market operator and builder from San Francisco.</p>
			<p>Previously, I was a consultant at Bain and Accenture. And before that, I was a multiple subjects teacher in Los Angeles.</p>
			<p>The problems I saw in education were big and messy and I didn't know how to think about it all. So I went into consulting and came out with a way to find the shape of ambiguous problems. I've since been working inside businesses and the work I love most is taking something a company has built that's awesome and getting it into the hands of more of the people it's for.</p>
			<p>I love wandering, understanding why people are the way they are, watching home tour vlogs (the things people collect and how they design their spaces are little autobiographies) and putting on a film score when I really need to focus (Interstellar, on repeat).</p>
		</div>
	</section>
</Layout>
