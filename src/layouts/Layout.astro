---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=IBM+Plex+Mono:wght@400&display=swap"
		/>
	</head>
	<body>
		<main class="container">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg: #FBF8F3;
		--ink: #1A1A1A;
		--muted: #6B6B6B;
		--accent: #4A5B7C;
		--accent-tint: rgba(74, 91, 124, 0.2);
		--sans: 'Inter', system-ui, sans-serif;
		--mono: 'IBM Plex Mono', monospace;
	}

	::selection {
		background: var(--accent-tint);
	}

	* {
		box-sizing: border-box;
	}

	html, body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--bg);
		color: var(--ink);
		font-family: var(--sans);
		font-size: 15px;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	.container {
		max-width: 860px;
		margin: 0 auto;
		padding: 120px 32px 80px;
	}

	/* Homepage opener */
	.opener {
		margin-left: calc(100px + 32px);
	}

	@media (max-width: 720px) {
		.opener {
			margin-left: 0;
		}
	}

	h1 {
		font-family: var(--sans);
		font-weight: 600;
		font-size: 32px;
		letter-spacing: -0.02em;
		margin: 0 0 8px;
	}

	.tagline {
		font-family: var(--mono);
		font-size: 14px;
		color: var(--muted);
		margin: 0 0 40px;
		letter-spacing: 0.02em;
	}

	.intro {
		margin: 0 0 32px;
	}

	.links {
		display: flex;
		flex-direction: row;
		gap: 24px;
		margin-top: 32px;
	}

	.links a {
		font-family: var(--mono);
		font-size: 14px;
		color: var(--ink);
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.links a:hover {
		color: var(--accent);
	}

	/* Section grid (home + sub-pages) */
	.section {
		display: grid;
		grid-template-columns: 100px 1fr;
		column-gap: 32px;
		margin-top: 96px;
	}

	.section:first-child {
		margin-top: 0;
	}

	@media (max-width: 720px) {
		.section {
			grid-template-columns: 1fr;
			row-gap: 16px;
		}
	}

	.section-label {
		font-family: var(--mono);
		font-size: 12px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0;
		padding-top: 18px;
	}

	/* Homepage list */
	.list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.list-item a {
		display: flex;
		align-items: baseline;
		gap: 24px;
		padding: 16px 0;
		color: var(--ink);
		text-decoration: none;
	}

	.list-item-main {
		flex: 1;
		min-width: 0;
	}

	.list-item-title {
		font-family: var(--sans);
		font-weight: 600;
		font-size: 14px;
		margin: 0 0 4px;
		letter-spacing: -0.01em;
	}

	.list-item-desc {
		font-family: var(--sans);
		font-size: 14px;
		color: var(--muted);
		margin: 0;
		line-height: 1.5;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.list-item-tag {
		font-family: var(--mono);
		font-size: 11px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		flex-shrink: 0;
	}

	.list-item a:hover .list-item-title {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	/* Prose */
	.prose p {
		margin: 0 0 20px;
	}

	.prose p:last-child {
		margin-bottom: 0;
	}

	.section > .prose {
		padding-top: 16px;
	}

	/* Sub-page article */
	.back-link {
		font-family: var(--mono);
		font-size: 12px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding-top: 0;
		text-decoration: none;
	}

	.back-link:hover {
		color: var(--accent);
	}

	.article-meta {
		font-family: var(--mono);
		font-size: 12px;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0 0 32px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.article-meta p {
		margin: 0;
	}

	.article-title {
		font-family: var(--sans);
		font-weight: 600;
		font-size: 28px;
		letter-spacing: -0.02em;
		margin: 0 0 8px;
	}

	.article-lead {
		font-family: var(--sans);
		font-size: 15px;
		color: var(--muted);
		margin: 0 0 16px;
	}
</style>
