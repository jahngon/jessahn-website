---
// Child Credit Freeze Tool — interactive widget.
//
// State data flow: the monitor repo updates its own state.public.json daily;
// `npm run sync-monitor-data` in this repo pulls the latest copy into
// public/widget/state.public.json. The widget reads only from same-origin.
//
// Step 1 combines the document picker (cards on top) with the live requirement
// matrix below it; Steps 2-4 cover what to copy, completing each form, and mailing.
const STATE_URL = '/widget/state.public.json';
const STALE_HOURS = 36;
---

<section
	id="tool"
	class="cff"
	data-state-url={STATE_URL}
	data-stale-hours={STALE_HOURS}
	aria-label="Child credit freeze tool"
>
	<div class="cff-loading">Loading current requirements…</div>
</section>

<script>
	const FRIENDLY_LABELS: Record<string, string> = {
		birth_child: "Child's birth certificate",
		ssn_child: "Child's Social Security card",
		id_child: "Child's gov-issued ID",
		id_parent: "Driver's license or other gov-issued ID",
		ssn_parent: "Parent's Social Security card",
		birth_parent: "Parent's birth certificate",
		utility: 'Utility bill, bank statement, or insurance bill',
		court: 'Court order, guardianship, or conservatorship',
		poa: 'Power of attorney',
		foster: 'Foster care certification',
	};

	type CategoryKey = 'authority' | 'parentId' | 'address' | 'childId';
	type BureauKey = 'equifax' | 'experian' | 'transunion';

	const CATEGORIES: { key: CategoryKey; label: string }[] = [
		{ key: 'authority', label: 'Authority' },
		{ key: 'parentId', label: 'Parent identity' },
		{ key: 'address', label: 'Address' },
		{ key: 'childId', label: 'Child identity' },
	];

	const BUREAUS: { key: BureauKey; name: string }[] = [
		{ key: 'equifax', name: 'Equifax' },
		{ key: 'experian', name: 'Experian' },
		{ key: 'transunion', name: 'TransUnion' },
	];

	const PICKER_SECTIONS: { title: string; docIds: string[] }[] = [
		{ title: 'About the child', docIds: ['birth_child', 'ssn_child', 'id_child'] },
		{
			title: 'Parent / Guardian',
			docIds: ['id_parent', 'ssn_parent', 'birth_parent', 'utility'],
		},
		{
			title: 'Guardianship & Custody',
			docIds: ['court', 'poa', 'foster'],
		},
	];

	type RawCategory = { logic: string; options: string[]; notes?: string };
	type RawDocument = { id: string; label: string; description?: string };
	type RawMailingAddress = { lines: string[]; notes?: string };
	type RawForm = {
		url: string;
		type: 'pdf_form' | 'online_form' | 'letter';
		resolves: boolean;
		contentHash?: string;
		notes?: string;
	};
	type RawBureau = {
		bureau: string;
		sourceUrl: string;
		documents: RawDocument[];
		categories: Record<string, RawCategory>;
		mailingAddress: RawMailingAddress;
		form: RawForm;
	};
	type RawState = { lastChecked: string; lastChanged: string; bureaus: RawBureau[] };

	// Inline SVG icons — minimal Tabler-style line icons. No external dependency.
	const ICON_COPY =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="8" y="8" width="12" height="12" rx="2"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>';
	const ICON_CHECK =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>';
	const ICON_MAILBOX =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>';
	const ICON_FILE_TEXT =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h9l5 5v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M14 3v6h6"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="14" y2="17"/></svg>';
	const ICON_WORLD =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><line x1="3" y1="12" x2="21" y2="12"/><path d="M12 3a13 13 0 0 1 0 18"/><path d="M12 3a13 13 0 0 0 0 18"/></svg>';
	const ICON_WRITING =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20h4l10-10-4-4L4 16v4z"/><line x1="13.5" y1="6.5" x2="17.5" y2="10.5"/></svg>';
	const ICON_DOWNLOAD =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v12"/><path d="M7 11l5 5 5-5"/><path d="M5 20h14"/></svg>';
	const ICON_EXTERNAL =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 4h6v6"/><line x1="10" y1="14" x2="20" y2="4"/><path d="M19 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6"/></svg>';
	const ICON_CHEVRON_DOWN =
		'<svg class="cff-icon cff-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>';
	const ICON_ALERT_TRIANGLE =
		'<svg class="cff-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l10 18H2z"/><line x1="12" y1="10" x2="12" y2="14"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';

	// Google Docs "make a copy" URL. The /copy suffix is what triggers Google's
	// "Copy document?" dialog so visitors get their own private copy in their Drive,
	// not view access to the source template. The doc itself must be shared as
	// "anyone with the link → viewer" for this to work for visitors.
	// To regenerate: re-upload public/widget/transunion-letter-bracketed.docx,
	// re-open as Google Doc, re-share, paste the share URL here and swap /edit?... → /copy.
	const GOOGLE_DOCS_TEMPLATE_URL =
		'https://docs.google.com/document/d/1LyqRaQiw6OuxN9YNxEcD9PZY8dZ01qWYK5t8_z2T2yE/copy';

	/** Selected document IDs. Lives only in memory; resets on page reload. */
	const selected = new Set<string>();
	let state: RawState | null = null;

	type AgeBand = 'under_16' | '16_or_17';
	let ageBand: AgeBand = 'under_16';

	const SELF_REQUEST_URLS: Record<BureauKey, string> = {
		equifax: 'https://www.equifax.com/personal/credit-report-services/credit-freeze/',
		experian: 'https://www.experian.com/freeze/center.html',
		transunion: 'https://www.transunion.com/credit-freeze',
	};

	const BUREAU_INFO_URLS: Record<BureauKey, string> = {
		equifax:
			'https://www.equifax.com/personal/education/identity-theft/articles/-/learn/freezing-your-childs-credit-report-faq/',
		experian: 'https://www.experian.com/help/minor-request.html',
		transunion: 'https://www.transunion.com/credit-freeze/credit-freeze-faq',
	};

	function escapeHtml(s: string): string {
		return s
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	function formatDate(iso: string): string {
		return new Date(iso).toLocaleDateString('en-US', {
			month: 'long',
			day: 'numeric',
			year: 'numeric',
		});
	}

	/** "May 19, 2026 at 10:09 PM" — date + time in visitor's local timezone.
	 * Used in freshness indicators so changes that land mid-day are visible. */
	function formatDateTime(iso: string): string {
		const d = new Date(iso);
		const date = d.toLocaleDateString('en-US', {
			month: 'long',
			day: 'numeric',
			year: 'numeric',
		});
		const time = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
		return `${date} at ${time}`;
	}

	function isStale(iso: string, staleHours: number): boolean {
		const hours = (Date.now() - new Date(iso).getTime()) / (1000 * 60 * 60);
		return hours > staleHours;
	}

	function friendlyLabel(id: string, fallback?: string): string {
		return FRIENDLY_LABELS[id] || fallback || id;
	}

	function validateState(data: unknown): string | null {
		if (!data || typeof data !== 'object') return 'not an object';
		const d = data as Partial<RawState>;
		if (typeof d.lastChecked !== 'string') return 'missing lastChecked';
		if (!Array.isArray(d.bureaus)) return 'bureaus is not an array';
		for (const b of d.bureaus) {
			if (!b.bureau || typeof b.bureau !== 'string') return 'bureau name missing';
			if (!Array.isArray(b.documents)) return `${b.bureau}: documents not array`;
			if (!b.categories || typeof b.categories !== 'object') {
				return `${b.bureau}: categories missing`;
			}
			for (const cat of ['authority', 'parentId', 'address', 'childId'] as const) {
				const c = b.categories[cat];
				if (!c || !Array.isArray(c.options) || typeof c.logic !== 'string') {
					return `${b.bureau}.categories.${cat}: shape invalid`;
				}
			}
			if (!b.mailingAddress || !Array.isArray(b.mailingAddress.lines)) {
				return `${b.bureau}: mailingAddress missing or malformed`;
			}
		}
		return null;
	}

	function isCategorySatisfied(cat: RawCategory): boolean {
		if (cat.logic === 'na' || cat.options.length === 0) return true;
		if (cat.logic === 'or') return cat.options.some((id) => selected.has(id));
		if (cat.logic === 'and') return cat.options.every((id) => selected.has(id));
		return false;
	}

	function renderCell(bureau: RawBureau, catKey: CategoryKey): string {
		const cat = bureau.categories[catKey];
		if (!cat) return '<td class="cff-cell cff-cell-empty">—</td>';

		if (cat.logic === 'na' || cat.options.length === 0) {
			return '<td class="cff-cell cff-cell-na">Not required</td>';
		}

		const satisfied = isCategorySatisfied(cat);
		const docMap = new Map(bureau.documents.map((d) => [d.id, d]));
		const logicLabel =
			cat.logic === 'or' ? 'Any one of' : cat.logic === 'and' ? 'All of' : cat.logic;

		const items = cat.options
			.map((id) => {
				const label = friendlyLabel(id, docMap.get(id)?.label);
				const isSelected = selected.has(id);
				return `<li class="cff-cell-doc${isSelected ? ' cff-cell-doc-selected' : ''}">${
					isSelected ? '<span class="cff-cell-check" aria-hidden="true">✓</span> ' : ''
				}${escapeHtml(label)}</li>`;
			})
			.join('');

		return `<td class="cff-cell${satisfied ? ' cff-cell-satisfied' : ''}"><div class="cff-cell-logic">${escapeHtml(logicLabel)}</div><ul class="cff-cell-docs">${items}</ul></td>`;
	}

	function renderMatrix(): string {
		if (!state) return '';
		const bureausByKey = new Map(state.bureaus.map((b) => [b.bureau, b]));
		let html = '';
		html += '<div class="cff-matrix-scroll" id="cff-matrix-scroll">';
		html += '<table class="cff-matrix" aria-label="Document requirements by bureau">';
		html += '<colgroup><col class="cff-col-bureau" />';
		for (let i = 0; i < CATEGORIES.length; i++) {
			html += '<col class="cff-col-cat" />';
		}
		html += '</colgroup>';
		html += '<thead><tr><th scope="col"></th>';
		for (const c of CATEGORIES) {
			html += `<th scope="col">${escapeHtml(c.label)}</th>`;
		}
		html += '</tr></thead><tbody>';
		for (const b of BUREAUS) {
			const bureau = bureausByKey.get(b.key);
			if (!bureau) continue;
			const infoUrl = BUREAU_INFO_URLS[b.key];
			html += `<tr><th scope="row"><a class="cff-bureau-link" href="${escapeHtml(infoUrl)}" target="_blank" rel="noopener">${escapeHtml(b.name)}${ICON_EXTERNAL}</a></th>`;
			for (const c of CATEGORIES) {
				html += renderCell(bureau, c.key);
			}
			html += '</tr>';
		}
		html += '</tbody></table></div>';
		return html;
	}

	/**
	 * Step 1 (combined). Formerly two steps — "know what each bureau requires"
	 * (the matrix) and "select your documents" (the picker). Now merged so the
	 * document cards sit on top as the first interactive thing a visitor touches,
	 * with the live requirement matrix directly below turning green as selections
	 * satisfy each bureau.
	 */
	function renderStep1(): string {
		if (!state) return '';
		const stale = isStale(state.lastChecked, getStaleHours());

		let html = '';
		html += '<div class="cff-step">';
		html += '<header class="cff-step-header">';
		html += '<h2 class="cff-step-title">Step 1: Select documents to meet bureau requirements</h2>';
		html += `<span class="cff-status ${stale ? 'cff-status-stale' : 'cff-status-fresh'}">`;
		html += '<span class="cff-status-dot" aria-hidden="true"></span>';
		html += `Last checked ${escapeHtml(formatDateTime(state.lastChecked))}`;
		if (stale) {
			html += ' <span class="cff-status-warning">(may be out of date)</span>';
		}
		html += '</span></header>';
		html +=
			'<p class="cff-step-hint">Click each document you have. The requirement matrix below updates live, turning green as your selections satisfy each bureau.</p>';

		// Picker cards first — the first interactive element on the page.
		for (const section of PICKER_SECTIONS) {
			html += '<div class="cff-picker-section">';
			html += `<h3 class="cff-picker-eyebrow">${escapeHtml(section.title)}</h3>`;
			html += '<div class="cff-card-grid">';
			for (const id of section.docIds) {
				const label = friendlyLabel(id);
				const isSelected = selected.has(id);
				html += `<button type="button" class="cff-card${isSelected ? ' cff-card-selected' : ''}" data-doc-id="${escapeHtml(id)}" aria-pressed="${isSelected}">`;
				html += '<span class="cff-card-check" aria-hidden="true"></span>';
				html += `<span class="cff-card-label">${escapeHtml(label)}</span>`;
				html += '</button>';
			}
			html += '</div></div>';
		}

		// Progress banner + the live matrix, below the cards.
		html += '<div id="cff-banner-slot">' + renderBanner() + '</div>';
		html += '<div id="cff-matrix-container">';
		html += renderMatrix();
		html += '</div>';

		html += '</div>';
		return html;
	}

	/** Bureaus whose option list (across any category) includes this docId. */
	function bureausForDoc(docId: string): { key: string; name: string }[] {
		if (!state) return [];
		const cats: CategoryKey[] = ['authority', 'parentId', 'address', 'childId'];
		const result: { key: string; name: string }[] = [];
		for (const bureau of state.bureaus) {
			const found = cats.some((c) => bureau.categories[c]?.options.includes(docId));
			if (found) {
				const display = BUREAUS.find((b) => b.key === bureau.bureau);
				result.push({ key: bureau.bureau, name: display?.name || bureau.bureau });
			}
		}
		return result;
	}

	function bureauReady(bureau: RawBureau): boolean {
		const cats: CategoryKey[] = ['authority', 'parentId', 'address', 'childId'];
		return cats.every((c) => isCategorySatisfied(bureau.categories[c]));
	}

	function renderBanner(): string {
		if (!state) return '';
		const bureausByKey = new Map(state.bureaus.map((b) => [b.bureau, b]));
		const total = BUREAUS.length;
		let readyCount = 0;
		let chips = '';
		for (const b of BUREAUS) {
			const bureau = bureausByKey.get(b.key);
			const ready = bureau ? bureauReady(bureau) : false;
			if (ready) readyCount++;
			chips += `<span class="cff-progress-chip${ready ? ' cff-progress-chip-ready' : ''}">`;
			if (ready) chips += '<span class="cff-progress-chip-check" aria-hidden="true">✓</span>';
			chips += escapeHtml(b.name);
			chips += '</span>';
		}
		const allReady = readyCount === total;
		const text = allReady
			? `<strong>${readyCount} / ${total} bureaus ready.</strong> See your mailing summary below.`
			: `<strong>${readyCount} / ${total} bureaus ready.</strong>`;
		const klass = allReady ? 'cff-banner-met' : 'cff-banner-pending';
		return (
			`<div class="cff-banner ${klass}" role="status">` +
			`<span class="cff-banner-text">${text}</span>` +
			`<div class="cff-progress" aria-hidden="true">${chips}</div>` +
			'</div>'
		);
	}

	function renderSummary(): string {
		if (!state) return '';

		// Walk selected in a stable order matching the picker layout.
		const orderedIds: string[] = [];
		for (const section of PICKER_SECTIONS) {
			for (const id of section.docIds) {
				if (selected.has(id)) orderedIds.push(id);
			}
		}
		for (const id of selected) {
			if (!orderedIds.includes(id)) orderedIds.push(id);
		}

		const rows = orderedIds
			.map((id) => {
				const bureaus = bureausForDoc(id);
				if (bureaus.length === 0) return null;
				return {
					label: friendlyLabel(id),
					sendTo: bureaus.map((b) => b.name).join(', '),
					copies: bureaus.length,
				};
			})
			.filter((r): r is { label: string; sendTo: string; copies: number } => r !== null);

		const isEmpty = rows.length === 0;

		let html = '';
		html += '<div class="cff-step">';
		html += '<header class="cff-step-header">';
		html += '<h2 class="cff-step-title">Step 2: What to make copies of and mail</h2>';
		html += '</header>';

		if (isEmpty) {
			html +=
				'<p class="cff-step-hint">Select your documents above to see what to copy and which bureau each one goes to.</p>';
		} else {
			html +=
				'<p class="cff-step-hint">You should now have a clear picture of what to photocopy. Below shows which documents go in each bureau’s envelope.</p>';
			html += '<div class="cff-summary-scroll"><table class="cff-summary" aria-label="Documents to copy and mail">';
			html += '<thead><tr>';
			html += '<th scope="col">Document</th>';
			html += '<th scope="col">Send to</th>';
			html += '<th scope="col" class="cff-summary-num">Copies</th>';
			html += '</tr></thead><tbody>';
			for (const row of rows) {
				html += `<tr><td>${escapeHtml(row.label)}</td><td>${escapeHtml(row.sendTo)}</td><td class="cff-summary-num">${row.copies}</td></tr>`;
			}
			html += '</tbody></table></div>';
			html +=
				'<div class="cff-warning"><strong>Always send copies, never originals.</strong> Bureaus do not return mailed documents.</div>';
		}

		html += '</div>';
		return html;
	}

	function renderStep4(): string {
		if (!state) return '';

		const bureausByKey = new Map(state.bureaus.map((b) => [b.bureau, b]));
		const equifax = bureausByKey.get('equifax');
		const experian = bureausByKey.get('experian');

		let html = '';
		html += '<div class="cff-step">';
		html += '<header class="cff-step-header">';
		html += '<h2 class="cff-step-title">Step 3: Complete form for each bureau</h2>';
		html += '</header>';
		html +=
			"<p class=\"cff-step-hint\">You'll send a separate request to all three. Each one works a little differently.</p>";

		html += '<div class="cff-submit-grid">';

		// Equifax column — PDF form
		if (equifax) {
			html += '<div class="cff-submit-card">';
			html += '<div class="cff-submit-bureau">Equifax</div>';
			html += `<div class="cff-submit-tag">${ICON_FILE_TEXT}<span>PDF form</span></div>`;
			html +=
				"<p class=\"cff-submit-desc\">Download Equifax's printable form, fill it in, and mail it with your document copies.</p>";
			html += `<a class="cff-submit-action" href="${escapeHtml(equifax.form.url)}" target="_blank" rel="noopener">${ICON_DOWNLOAD}<span>Get form</span></a>`;
			html += '</div>';
		}

		// Experian column — online form
		if (experian) {
			html += '<div class="cff-submit-card">';
			html += '<div class="cff-submit-bureau">Experian</div>';
			html += `<div class="cff-submit-tag">${ICON_WORLD}<span>Online form</span></div>`;
			html +=
				"<p class=\"cff-submit-desc\">Fill in Experian's online form, then print the completed page to mail with your copies.</p>";
			html += `<a class="cff-submit-action" href="${escapeHtml(experian.form.url)}" target="_blank" rel="noopener">${ICON_EXTERNAL}<span>Go to form</span></a>`;
			html +=
				'<p class="cff-submit-note"><strong>Note:</strong> Experian also offers a direct online upload option.</p>';
			html += '</div>';
		}

		// TransUnion column — letter template with three pill-style action buttons
		const gdocsReady = GOOGLE_DOCS_TEMPLATE_URL !== 'PLACEHOLDER_NOT_SET_YET';
		html += '<div class="cff-submit-card">';
		html += '<div class="cff-submit-bureau">TransUnion</div>';
		html += `<div class="cff-submit-tag">${ICON_WRITING}<span>Letter</span></div>`;
		html +=
			'<p class="cff-submit-desc">Requires written request. Here is a fill-in template that you can use, print and mail with your copies.</p>';

		html += '<div class="cff-tu-actions">';

		// Word and Markdown share the first row — both are direct downloads
		html += '<div class="cff-tu-downloads-row">';
		html +=
			'<a class="cff-submit-action" href="/widget/transunion-letter-bracketed.docx" download>' +
			ICON_DOWNLOAD +
			'<span>Word</span>' +
			'</a>';
		html +=
			'<a class="cff-submit-action" href="/widget/transunion-letter-bracketed.md" download>' +
			ICON_DOWNLOAD +
			'<span>Markdown</span>' +
			'</a>';
		html += '</div>';

		// Google Docs — toggle button; warning + link inside expanded panel
		html +=
			'<button type="button" class="cff-submit-action cff-tu-gdocs-toggle" aria-expanded="false" aria-controls="cff-gdocs-panel">' +
			'<span>Google Docs</span>' +
			`<span class="cff-tu-chevron-wrap">${ICON_CHEVRON_DOWN}</span>` +
			'</button>';

		html += '<div id="cff-gdocs-panel" class="cff-tu-gdocs-panel" hidden>';
		html += `<div class="cff-tu-warning"><span class="cff-tu-warning-icon">${ICON_ALERT_TRIANGLE}</span><span>The information you fill in will be saved in your Google Drive until you delete it.</span></div>`;
		if (gdocsReady) {
			html += `<a class="cff-submit-action" href="${escapeHtml(GOOGLE_DOCS_TEMPLATE_URL)}" target="_blank" rel="noopener">${ICON_EXTERNAL}<span>Open in Google Docs</span></a>`;
		} else {
			html +=
				'<p class="cff-tu-gdocs-placeholder">Google Docs link not configured yet — set <code>GOOGLE_DOCS_TEMPLATE_URL</code> in this component to enable.</p>';
		}
		html += '</div>';

		html += '</div>'; // /cff-tu-actions
		html += '</div>'; // /TransUnion card

		html += '</div>'; // /cff-submit-grid
		html += '</div>'; // /cff-step
		return html;
	}

	function renderStep5(): string {
		if (!state) return '';

		const stale = isStale(state.lastChecked, getStaleHours());
		const bureausByKey = new Map(state.bureaus.map((b) => [b.bureau, b]));

		let html = '';
		html += '<div class="cff-step">';
		html += '<header class="cff-step-header">';
		html += '<h2 class="cff-step-title">Step 4: Mail each request</h2>';
		// Freshness badge inline in the header, mirroring Step 1's visual treatment.
		html += `<span class="cff-status ${stale ? 'cff-status-stale' : 'cff-status-fresh'}">`;
		html += '<span class="cff-status-dot" aria-hidden="true"></span>';
		html += `Last checked ${escapeHtml(formatDateTime(state.lastChecked))}`;
		if (stale) {
			html += ' <span class="cff-status-warning">(may be out of date)</span>';
		}
		html += '</span>';
		html += '</header>';
		html +=
			"<p class=\"cff-step-hint\">Send each bureau's form or letter, along with your document copies, to the matching address below.</p>";

		// Three-column address card grid
		html += '<div class="cff-address-grid">';
		for (const b of BUREAUS) {
			const bureau = bureausByKey.get(b.key);
			if (!bureau) continue;
			const lines = bureau.mailingAddress.lines;
			const addressText = lines.join('\n');
			html += '<div class="cff-address-card">';
			html += `<div class="cff-address-bureau">${escapeHtml(b.name)}</div>`;
			html += '<div class="cff-address-lines">';
			for (const ln of lines) {
				html += `<div>${escapeHtml(ln)}</div>`;
			}
			html += '</div>';
			html += `<button type="button" class="cff-copy-btn" data-address-text="${escapeHtml(addressText)}">${ICON_COPY}<span class="cff-copy-btn-label">Copy address</span></button>`;
			html += '</div>';
		}
		html += '</div>';

		// Mail guidance note
		html += '<div class="cff-mail-note">';
		html += `<span class="cff-mail-note-icon">${ICON_MAILBOX}</span>`;
		html +=
			"<span>Because you're mailing copies of sensitive documents, consider sending each request by <strong>certified mail</strong> and adding a <strong>return receipt</strong> which gives you back a signed confirmation that the bureau received it. Useful if a freeze confirmation never arrives and you need proof you sent it.</span>";
		html += '</div>';

		html += '</div>';
		return html;
	}

	function renderAgeGate(): string {
		const under16Selected = ageBand === 'under_16';
		const teenSelected = ageBand === '16_or_17';
		return (
			'<div class="cff-age-gate">' +
			'<label class="cff-age-label" for="cff-age-select"><span class="cff-age-label-text">Child\'s age</span>' +
			'<select class="cff-age-select" id="cff-age-select">' +
			`<option value="under_16"${under16Selected ? ' selected' : ''}>Under 16</option>` +
			`<option value="16_or_17"${teenSelected ? ' selected' : ''}>16 or 17</option>` +
			'</select>' +
			'</label>' +
			'</div>'
		);
	}

	function renderBlocker(): string {
		const items = BUREAUS.map(
			(b) =>
				`<li><a href="${escapeHtml(SELF_REQUEST_URLS[b.key])}" target="_blank" rel="noopener">${escapeHtml(b.name)}'s credit freeze page</a></li>`
		).join('');
		return (
			'<div class="cff-blocker">' +
			'<h2 class="cff-blocker-title">This tool is for children under 16</h2>' +
			'<p>At 16 or older, the freeze must be requested by the child directly — not by a parent. Each bureau has its own self-request page:</p>' +
			`<ul class="cff-blocker-links">${items}</ul>` +
			'</div>'
		);
	}

	function renderBody(): string {
		if (ageBand === '16_or_17') {
			return renderBlocker();
		}
		let html = '';
		html += renderStep1(); // combined picker cards + live matrix
		html += '<div id="cff-step3-slot">' + renderSummary() + '</div>';
		html += renderStep4();
		html += renderStep5();
		return html;
	}

	function renderAll(): string {
		let html = '';
		html += renderAgeGate();
		html += '<div id="cff-body">' + renderBody() + '</div>';
		return html;
	}

	function renderError(message: string): string {
		return `<div class="cff-error"><strong>Couldn't load current bureau requirements.</strong> ${escapeHtml(message)} Please refresh the page, or contact the site owner if the problem persists.</div>`;
	}

	function getStaleHours(): number {
		const widget = document.querySelector<HTMLElement>('.cff');
		return Number(widget?.dataset.staleHours) || 36;
	}

	/** After interaction: re-render matrix, banner, and the Step 2 summary. Picker DOM stays stable. */
	function refreshDynamic(): void {
		const matrixContainer = document.getElementById('cff-matrix-container');
		if (matrixContainer) matrixContainer.innerHTML = renderMatrix();
		const bannerSlot = document.getElementById('cff-banner-slot');
		if (bannerSlot) bannerSlot.innerHTML = renderBanner();
		const step3Slot = document.getElementById('cff-step3-slot');
		if (step3Slot) step3Slot.innerHTML = renderSummary();
	}

	/** Toggle the doc on the clicked card, update its DOM, and refresh the dynamic regions. */
	function handleCardClick(card: HTMLButtonElement): void {
		const id = card.dataset.docId;
		if (!id) return;
		if (selected.has(id)) {
			selected.delete(id);
			card.setAttribute('aria-pressed', 'false');
			card.classList.remove('cff-card-selected');
		} else {
			selected.add(id);
			card.setAttribute('aria-pressed', 'true');
			card.classList.add('cff-card-selected');
		}
		refreshDynamic();
	}

	function handleAgeChange(value: string): void {
		ageBand = value === '16_or_17' ? '16_or_17' : 'under_16';
		const body = document.getElementById('cff-body');
		if (body) body.innerHTML = renderBody();
	}

	function handleCopyAddress(button: HTMLButtonElement): void {
		const text = button.dataset.addressText;
		if (!text) return;
		const original = button.innerHTML;
		const restore = () => {
			button.innerHTML = original;
			button.classList.remove('cff-copy-btn-success');
			button.disabled = false;
		};
		const success = () => {
			button.innerHTML = ICON_CHECK + '<span class="cff-copy-btn-label">Copied</span>';
			button.classList.add('cff-copy-btn-success');
			button.disabled = true;
			window.setTimeout(restore, 1500);
		};
		// Browsers without clipboard API or where it's blocked still fall back gracefully
		// by showing the Copied state — the address is still visible to the user.
		if (navigator.clipboard && navigator.clipboard.writeText) {
			navigator.clipboard.writeText(text).then(success).catch(() => success());
		} else {
			success();
		}
	}

	function handleGdocsToggle(button: HTMLButtonElement): void {
		const expanded = button.getAttribute('aria-expanded') === 'true';
		button.setAttribute('aria-expanded', expanded ? 'false' : 'true');
		const panelId = button.getAttribute('aria-controls');
		if (panelId) {
			const panel = document.getElementById(panelId);
			if (panel) {
				if (expanded) {
					panel.setAttribute('hidden', '');
				} else {
					panel.removeAttribute('hidden');
				}
			}
		}
	}

	function wireEvents(widget: HTMLElement): void {
		widget.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			const gdocsToggle = target.closest<HTMLButtonElement>('.cff-tu-gdocs-toggle');
			if (gdocsToggle && widget.contains(gdocsToggle)) {
				handleGdocsToggle(gdocsToggle);
				return;
			}
			const copyBtn = target.closest<HTMLButtonElement>('.cff-copy-btn');
			if (copyBtn && widget.contains(copyBtn)) {
				handleCopyAddress(copyBtn);
				return;
			}
			const card = target.closest<HTMLButtonElement>('.cff-card');
			if (card && widget.contains(card)) {
				handleCardClick(card);
			}
		});
		widget.addEventListener('change', (e) => {
			const target = e.target as HTMLElement;
			if (target instanceof HTMLSelectElement && target.id === 'cff-age-select') {
				handleAgeChange(target.value);
			}
		});
	}

	async function init(): Promise<void> {
		const widget = document.querySelector<HTMLElement>('.cff');
		if (!widget) return;
		const url = widget.dataset.stateUrl;
		if (!url) {
			widget.innerHTML = renderError('Widget is misconfigured (no data URL).');
			return;
		}

		try {
			const res = await fetch(url, { cache: 'no-store' });
			if (!res.ok) {
				widget.innerHTML = renderError(`Server returned HTTP ${res.status}.`);
				return;
			}
			let parsed: unknown;
			try {
				parsed = await res.json();
			} catch (e) {
				widget.innerHTML = renderError(
					`Data file is not valid JSON: ${e instanceof Error ? e.message : String(e)}.`
				);
				return;
			}
			const err = validateState(parsed);
			if (err) {
				widget.innerHTML = renderError(`Data file does not match expected shape: ${err}.`);
				return;
			}
			state = parsed as RawState;
			widget.innerHTML = renderAll();
			wireEvents(widget);
		} catch (err) {
			widget.innerHTML = renderError(err instanceof Error ? err.message : String(err));
		}
	}

	init();
</script>

