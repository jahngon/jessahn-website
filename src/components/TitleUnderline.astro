---
interface Props {
	variant?: 'frozen';
}
const { variant } = Astro.props;
---

{variant === 'frozen' && (
	<svg
		class="title-underline"
		viewBox="0 0 450 24"
		preserveAspectRatio="xMinYMid meet"
		stroke="#1B4FCC"
		stroke-width="2.5"
		stroke-linecap="round"
		stroke-linejoin="miter"
		stroke-miterlimit="4"
		fill="none"
		aria-hidden="true"
	>
		<path d="M 4 12 L 26 4 L 50 18 L 78 7 L 108 16 L 142 3 L 178 14 L 212 6 L 246 19 L 282 5 L 318 15 L 352 8 L 388 17 L 420 6 L 446 12" />
	</svg>
)}

<style>
	.title-underline {
		display: block;
		width: 100%;
		max-width: 480px;
		height: auto;
		margin: -14px 0 18px;
	}
</style>
